{
  "manifest_version": 3,
  "name": "Focus Pro",
  "version": "3.2",
  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["eye_tracker_content.js"],
      "run_at": "document_idle"
    }
  ]
}